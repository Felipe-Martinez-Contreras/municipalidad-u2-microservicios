# ─── GENERAL ──────────────────────────────────────────────────────────────────
DEBUG=False

# ─── JWT (compartido entre todos los servicios) ───────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-shared-across-all-services

# ─── SERVICIO AUTH ────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=your-auth-django-secret-key
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=your-auth-db-password

# ─── SERVICIO TRÁMITES ────────────────────────────────────────────────────────
TRAMITES_SECRET_KEY=your-tramites-django-secret-key
TRAMITES_DB_NAME=tramites_db
TRAMITES_DB_USER=tramites_user
TRAMITES_DB_PASSWORD=your-tramites-db-password

# ─── SERVICIO BODEGA ──────────────────────────────────────────────────────────
BODEGA_SECRET_KEY=your-bodega-django-secret-key
BODEGA_DB_NAME=bodega_db
BODEGA_DB_USER=bodega_user
BODEGA_DB_PASSWORD=your-bodega-db-password

# ─── GRAFANA ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-passwordPORTAL_SECRET_KEY=your-portal-django-secret-key
